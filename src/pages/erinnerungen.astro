---
import { Image, getImage } from "astro:assets";
import FancyLayout from "../layouts/FancyLayout.astro";

import img1 from "../assets/IMG-20260508-WA0007.jpg";
import img2 from "../assets/IMG-20260508-WA0029.jpg";
import img3 from "../assets/IMG-20260508-WA0030.jpg";
import img4 from "../assets/IMG-20260509-WA0017.jpg";
import img5 from "../assets/IMG-20260509-WA0020.jpg";
import img6 from "../assets/IMG-20260513-WA0000.jpg";
import img7 from "../assets/IMG-20260513-WA0001.jpg";
import img8 from "../assets/IMG-20260513-WA0022.jpg";
import img9 from "../assets/IMG-20260514-WA0003.jpg";
import img10 from "../assets/IMG-20260514-WA0010.jpg";

const rawImages = [img1, img2, img3, img4, img5, img6, img7, img8, img9, img10];

// Generate optimised full-size URLs (capped at 1600px wide) for the lightbox
const fullImages = await Promise.all(
  rawImages.map((img) => getImage({ src: img, width: 1600, format: "webp" }))
);
---

<FancyLayout title="Erinnerungen">
  <div class="prose">
    <h2>Erinnerungen</h2>
    <p>Ein paar Momente, die wir festgehalten haben.</p>
  </div>

  <div class="gallery wide">
    {rawImages.map((img, i) => (
      <button
        class="item"
        data-index={i}
        data-src={fullImages[i].src}
        aria-label={`Foto ${i + 1} öffnen`}
      >
        <Image
          src={img}
          alt={`Hochzeitsfoto ${i + 1}`}
          widths={[400, 800]}
          sizes="(min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw"
        />
      </button>
    ))}
  </div>

  <div class="prose" style="margin-top: 2rem;">
    <a href="/">← Zurück zur Startseite</a>
  </div>

  <!-- Lightbox -->
  <div id="lightbox" role="dialog" aria-modal="true" aria-label="Bildansicht" hidden>
    <button id="lb-close" aria-label="Schließen">&#x2715;</button>
    <button id="lb-prev" aria-label="Vorheriges Bild">&#x2039;</button>
    <button id="lb-next" aria-label="Nächstes Bild">&#x203A;</button>
    <div id="lb-viewport">
      <img id="lb-img" src="" alt="" />
    </div>
    <div id="lb-counter"></div>
  </div>
</FancyLayout>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  @media (max-width: 600px) {
    .gallery { grid-template-columns: 1fr; }
  }
  @media (min-width: 601px) and (max-width: 900px) {
    .gallery { grid-template-columns: repeat(2, 1fr); }
  }

  .item {
    display: block;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    overflow: hidden;
  }

  .item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 1;
    transition: opacity 0.2s;
  }

  .item:hover img { opacity: 0.9; }

  /* ── Lightbox ── */
  #lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #lightbox[hidden] { display: none; }

  #lb-viewport {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #lightbox:not([hidden]) #lb-viewport {
    touch-action: none; /* only block touch when lightbox is open */
  }

  #lb-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
    transform-origin: center center;
    will-change: transform;
  }

  #lb-close,
  #lb-prev,
  #lb-next {
    position: fixed;
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    font-size: 2rem;
    line-height: 1;
    padding: 0.5rem;
    opacity: 0.8;
    transition: opacity 0.15s;
    z-index: 1001;
  }

  #lb-close:hover, #lb-prev:hover, #lb-next:hover { opacity: 1; }

  #lb-close { top: 1rem; right: 1rem; font-size: 1.5rem; }
  #lb-prev   { left: 0.75rem; top: 50%; transform: translateY(-50%); font-size: 3rem; }
  #lb-next   { right: 0.75rem; top: 50%; transform: translateY(-50%); font-size: 3rem; }

  #lb-counter {
    position: fixed;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.6);
    font-size: 0.85rem;
    font-family: var(--font-dm-sans), sans-serif;
    pointer-events: none;
  }
</style>

<script>
  const srcs: string[] = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".item[data-src]")
  ).map((el) => el.dataset.src!);

  const lb       = document.getElementById("lightbox")!;
  const lbImg    = document.getElementById("lb-img") as HTMLImageElement;
  const lbClose  = document.getElementById("lb-close")!;
  const lbPrev   = document.getElementById("lb-prev")!;
  const lbNext   = document.getElementById("lb-next")!;
  const lbCounter= document.getElementById("lb-counter")!;
  const viewport = document.getElementById("lb-viewport")!;

  let current = 0;
  let pinching = false;

  // ── open / close ──────────────────────────────────────────────────────────
  function openLightbox(index: number) {
    current = index;
    show();
    document.body.style.overflow = "hidden";
  }

  function close() {
    lb.hidden = true;
    document.body.style.overflow = "";
    restoreFlexLayout();
    pinching = false;
  }

  function show() {
    lbImg.src = srcs[current];
    lbImg.alt = `Hochzeitsfoto ${current + 1}`;
    lbCounter.textContent = `${current + 1} / ${srcs.length}`;
    lbPrev.style.display = current === 0 ? "none" : "";
    lbNext.style.display = current === srcs.length - 1 ? "none" : "";
    lb.hidden = false;
    restoreFlexLayout();
    pinching = false;
  }

  function prev() { if (current > 0) { current--; show(); } }
  function next() { if (current < srcs.length - 1) { current++; show(); } }

  document.querySelectorAll<HTMLButtonElement>(".item").forEach((btn) => {
    btn.addEventListener("click", () => openLightbox(Number(btn.dataset.index)));
  });

  lbClose.addEventListener("click", close);
  lbPrev.addEventListener("click", prev);
  lbNext.addEventListener("click", next);

  lb.addEventListener("click", (e) => { if (e.target === lb || e.target === viewport) close(); });

  document.addEventListener("keydown", (e) => {
    if (lb.hidden) return;
    if (e.key === "Escape")      close();
    if (e.key === "ArrowLeft")   prev();
    if (e.key === "ArrowRight")  next();
  });

  // ── pinch-zoom + pan ──────────────────────────────────────────────────────
  // We keep transform-origin fixed at "0 0" and represent the whole transform
  // as (panX, panY, scale), where the CSS is:
  //   transform: translate(panX, panY) scale(scale)
  // This means: first scale around 0,0, then translate.
  // To zoom around a focal point F (in viewport px):
  //   newPanX = F.x - (F.x - panX) * (newScale / scale)
  //   newPanY = F.y - (F.y - panY) * (newScale / scale)
  // All coordinates are in viewport (clientX/clientY) space — no getBoundingClientRect needed.

  let scale = 1;
  let panX = 0, panY = 0;

  function resetTransform() {
    scale = 1; panX = 0; panY = 0;
    applyTransform();
  }

  function applyTransform() {
    lbImg.style.transformOrigin = "0 0";
    lbImg.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
  }

  // When scale==1 the image is centred by flexbox. We need to know where the
  // image's top-left corner sits in viewport space so we can set panX/panY
  // correctly when the first pinch begins.
  function syncPanFromLayout() {
    // At scale==1 and no user pan, the image is centred by the flex container.
    // Read where it actually is and absorb that offset into panX/panY so the
    // math stays consistent from the very first touch.
    if (scale !== 1) return;
    const r = lbImg.getBoundingClientRect();
    // With transform-origin:0 0 and translate(panX,panY) scale(1):
    // r.left === panX  (since scale==1 means no scaling offset)
    panX = r.left;
    panY = r.top;
    // Now remove flexbox centering so our transform drives position instead
    lbImg.style.position = "absolute";
    lbImg.style.top = "0";
    lbImg.style.left = "0";
    applyTransform();
  }

  function restoreFlexLayout() {
    lbImg.style.position = "";
    lbImg.style.top = "";
    lbImg.style.left = "";
    lbImg.style.transform = "";
    lbImg.style.transformOrigin = "";
    scale = 1; panX = 0; panY = 0;
  }

  // pinch state — all in viewport (clientX/Y) coordinates
  let startDist = 0, startScale = 1;
  let startMidX = 0, startMidY = 0;   // focal point when pinch started
  let startPanX = 0, startPanY = 0;

  // swipe state
  let swipeStartX = 0, swipeStartY = 0, swiping = false;

  function tdist(a: Touch, b: Touch) {
    return Math.hypot(a.clientX - b.clientX, a.clientY - b.clientY);
  }
  function tmid(a: Touch, b: Touch) {
    return { x: (a.clientX + b.clientX) / 2, y: (a.clientY + b.clientY) / 2 };
  }

  viewport.addEventListener("touchstart", (e) => {
    if (e.touches.length === 2) {
      if (!pinching) {
        // First time we go to 2 fingers: absorb flexbox position
        if (scale === 1) syncPanFromLayout();
        pinching = true;
      }
      const t = Array.from(e.touches);
      startDist  = tdist(t[0], t[1]);
      startScale = scale;
      const m    = tmid(t[0], t[1]);
      startMidX  = m.x;
      startMidY  = m.y;
      startPanX  = panX;
      startPanY  = panY;
      swiping    = false;
    } else if (e.touches.length === 1) {
      swipeStartX = e.touches[0].clientX;
      swipeStartY = e.touches[0].clientY;
      swiping = true;
    }
  }, { passive: true });

  viewport.addEventListener("touchmove", (e) => {
    if (e.touches.length === 2) {
      swiping = false;
      e.preventDefault();
      const t = Array.from(e.touches);
      const newDist = tdist(t[0], t[1]);
      const newScale = Math.min(8, Math.max(1, startScale * (newDist / startDist)));

      // Current midpoint between fingers
      const m = tmid(t[0], t[1]);

      // Zoom around the original focal point (startMid), then account for
      // how much the midpoint has translated since the pinch started.
      const scaleRatio = newScale / startScale;
      panX = startMidX - scaleRatio * (startMidX - startPanX) + (m.x - startMidX);
      panY = startMidY - scaleRatio * (startMidY - startPanY) + (m.y - startMidY);
      scale = newScale;

      applyTransform();
    } else if (e.touches.length === 1 && swiping && scale <= 1) {
      const dx = e.touches[0].clientX - swipeStartX;
      const dy = e.touches[0].clientY - swipeStartY;
      if (Math.abs(dx) > Math.abs(dy) + 10 && Math.abs(dx) > 5) {
        e.preventDefault();
      }
    }
  }, { passive: false });

  viewport.addEventListener("touchend", (e) => {
    // Swipe-to-navigate (only when not zoomed)
    if (e.touches.length === 0 && swiping && scale <= 1) {
      const dx = e.changedTouches[0].clientX - swipeStartX;
      const dy = e.changedTouches[0].clientY - swipeStartY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
        if (dx < 0) next(); else prev();
      }
    }

    // Snap back to fit if pinch went below scale 1
    if (scale < 1) {
      restoreFlexLayout();
      pinching = false;
      return;
    }

    // When all fingers lift and we're back to scale==1, restore flex centering
    if (e.touches.length === 0 && scale <= 1) {
      restoreFlexLayout();
      pinching = false;
    }

    // Update swipe baseline if one finger remains
    if (e.touches.length === 1) {
      swipeStartX = e.touches[0].clientX;
      swipeStartY = e.touches[0].clientY;
      swiping = true;
    }
  }, { passive: true });

  // double-tap to reset zoom
  let lastTap = 0;
  viewport.addEventListener("touchend", () => {
    const now = Date.now();
    if (now - lastTap < 300) { restoreFlexLayout(); pinching = false; }
    lastTap = now;
  }, { passive: true });
</script>
