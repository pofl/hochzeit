---

---

<details class="card">
  <summary>
    <slot name="summary" />
    <span class="chevron" aria-hidden="true"></span>
  </summary>
  <div class="body">
    <slot />
  </div>
</details>

<style>
  .card {
    border-radius: 0.5rem;
    background: var(--surface-warm);
    border: 1px solid var(--border-soft);
    overflow: hidden;

    &[open] > summary {
      background: var(--surface-warm-hover);
    }

    > summary {
      list-style: none;
      cursor: pointer;
      padding: 0.9rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;

      @media (max-width: 640px) {
        padding: 0.75rem;
      }

      &::-webkit-details-marker {
        display: none;
      }

      &:focus-visible {
        outline: 2px solid var(--brown-tint-focus);
        outline-offset: 2px;
        border-radius: 0.35rem;
      }
    }

    .chevron {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      width: 1.4rem;
      height: 1.4rem;
      border-radius: 50%;
      background: var(--brown-tint);
      color: var(--brown);
      font-size: 0.7rem;
      transition: transform 0.2s ease;
      margin-left: auto;

      &::before {
        content: "▼";
      }
    }

    &[open] .chevron {
      transform: rotate(180deg);
    }

    .body {
      border-top: 1px solid var(--border-soft);
      background: #fff;
    }
  }
</style>
