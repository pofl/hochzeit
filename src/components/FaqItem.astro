---
import CollapsibleCard from "./CollapsibleCard.astro";
---

<CollapsibleCard>
  <span slot="summary" class="faq-question"><slot name="q" /></span>
  <div class="faq-answer"><slot name="a" /></div>
</CollapsibleCard>

<style>
  .faq-question {
    font-size: 0.95rem;
    font-weight: 600;

    @media (max-width: 640px) {
      font-size: 0.875rem;
    }
  }

  .faq-answer {
    margin: 0;
    padding: 0.85rem 1rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--brown-deeper);

    & > :global(p:first-child) {
      margin-top: 0;
    }

    & > :global(p:last-child) {
      margin-bottom: 0;
    }

    @media (max-width: 640px) {
      font-size: 0.85rem;
      padding: 0.75rem;
    }
  }
</style>
