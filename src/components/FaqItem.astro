---
import CollapsibleCard from "./CollapsibleCard.astro";

interface Props {
  q: string;
  a: string;
}

const { q, a } = Astro.props;
---

<CollapsibleCard>
  <span slot="summary" class="faq-question">{q}</span>
  <p class="faq-answer">{a}</p>
</CollapsibleCard>

<style>
  .faq-question {
    font-size: 0.95rem;
    font-weight: 600;

    @media (max-width: 640px) {
      font-size: 0.875rem;
    }
  }

  .faq-answer {
    margin: 0;
    padding: 0.85rem 1rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #3a2a1a;

    @media (max-width: 640px) {
      font-size: 0.85rem;
      padding: 0.75rem;
    }
  }
</style>
