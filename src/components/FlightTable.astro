---
interface Flight {
  guests: string;
  route: string;
  departure: string;
  arrival: string;
  type: "Direktflug" | "1 Umstieg" | "2 Umstiege";
  details: string;
}

interface Props {
  flights: Flight[];
}

const { flights } = Astro.props;
const headers = ["Gäste", "Strecke", "Abflug", "Ankunft", "Verbindung", "Details"];
---
<section class="flight-table" aria-label="Gebuchte Flüge">
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          {headers.map((header) => (
            <th>{header}</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {flights.map((flight) => (
          <tr>
            <td>{flight.guests}</td>
            <td>{flight.route}</td>
            <td>{flight.departure}</td>
            <td>{flight.arrival}</td>
            <td>{flight.type}</td>
            <td>{flight.details}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .flight-table {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1rem 0;
  }

  .table-wrapper {
    overflow-x: auto;
    border-radius: .5rem;
    background: #f9f6f1;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.05);
  }

  table {
    width: 100%;
    min-width: 780px;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  th,
  td {
    padding: 0.85rem 1rem;
    text-align: left;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  thead th {
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: #a15b00;
  }

  tbody tr:nth-child(even) {
    background: #fff;
  }

  tbody tr:nth-child(odd) {
    background: #f5efe7;
  }

  @media (max-width: 640px) {
    th,
    td {
      padding: 0.7rem 0.6rem;
      font-size: 0.85rem;
    }
  }
</style>
