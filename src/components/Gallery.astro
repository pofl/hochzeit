---
import { Image } from "astro:assets";

import img1 from "../assets/IMG-20260508-WA0007.jpg";
import img2 from "../assets/IMG-20260508-WA0029.jpg";
import img3 from "../assets/IMG-20260508-WA0030.jpg";
import img4 from "../assets/IMG-20260509-WA0017.jpg";
import img5 from "../assets/IMG-20260509-WA0020.jpg";
import img6 from "../assets/IMG-20260513-WA0000.jpg";
import img7 from "../assets/IMG-20260513-WA0001.jpg";
import img8 from "../assets/IMG-20260513-WA0022.jpg";
import img9 from "../assets/IMG-20260514-WA0003.jpg";
import img10 from "../assets/IMG-20260514-WA0010.jpg";

const images = [img8, img2, img3, img4, img10, img6, img5, img7, img1, img9];
---

<!-- Thumbnail grid -->
<div class="gallery wide" id="gallery">
  {
    images.map((img, i) => (
      <a href={`#foto-${i}`} class="item" aria-label={`Foto ${i + 1} öffnen`}>
        <Image
          src={img}
          alt={`Hochzeitsfoto ${i + 1}`}
          widths={[400, 800]}
          sizes="(min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw"
        />
      </a>
    ))
  }
</div>

<!-- Full-screen scroll-snap strip (hidden off-screen until an anchor is targeted) -->
<div class="strip" id="strip">
  <a href="#gallery" class="close" aria-label="Schließen">&#x2715;</a>
  {
    images.map((img, i) => (
      <div class="slide" id={`foto-${i}`}>
        <Image src={img} alt={`Hochzeitsfoto ${i + 1}`} widths={[800, 1600]} sizes="100vw" />
      </div>
    ))
  }
</div>

<style>
  /* ── Thumbnail grid ─────────────────────────────────────────────────────── */
  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  @media (max-width: 600px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
  @media (min-width: 601px) and (max-width: 900px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .item {
    display: block;
    overflow: hidden;
  }

  .item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 1;
    transition: opacity 0.2s;
  }

  .item:hover img {
    opacity: 0.85;
  }

  /* ── Full-screen strip ──────────────────────────────────────────────────── */
  /*
   * The strip is position:fixed and sits below the viewport (top: 100vh).
   * When any #foto-N anchor is targeted, :has(:target) moves it to top:0.
   * Pure CSS, no JS.
   */
  .strip {
    position: fixed;
    inset: 0;
    top: 100vh; /* hidden below viewport by default */
    background: #000;
    display: flex;
    flex-direction: row;
    overflow-x: scroll;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    transition: top 0s; /* instant — the anchor jump handles navigation */
    z-index: 100;
  }

  /* Show the strip when any slide is targeted */
  .strip:has(:target) {
    top: 0;
  }

  .slide {
    flex: 0 0 100vw;
    width: 100vw;
    height: 100dvh;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .slide img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    /* Let the browser handle pinch-zoom natively */
    touch-action: pan-x pan-y pinch-zoom;
  }

  .close {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 101;
    color: #fff;
    font-size: 1.5rem;
    line-height: 1;
    padding: 0.4rem 0.6rem;
    background: rgba(0, 0, 0, 0.45);
    border-radius: 4px;
    text-decoration: none;
    /* Only visible when strip is open */
    display: none;
  }

  .strip:has(:target) .close {
    display: block;
  }
</style>
