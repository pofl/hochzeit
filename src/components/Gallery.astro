---
import { Image, getImage } from "astro:assets";

import img1 from "../assets/IMG-20260508-WA0007.jpg";
import img2 from "../assets/IMG-20260508-WA0029.jpg";
import img3 from "../assets/IMG-20260508-WA0030.jpg";
import img4 from "../assets/IMG-20260509-WA0017.jpg";
import img5 from "../assets/IMG-20260509-WA0020.jpg";
import img6 from "../assets/IMG-20260513-WA0000.jpg";
import img7 from "../assets/IMG-20260513-WA0001.jpg";
import img8 from "../assets/IMG-20260513-WA0022.jpg";
import img9 from "../assets/IMG-20260514-WA0003.jpg";
import img10 from "../assets/IMG-20260514-WA0010.jpg";

const images = [img8, img2, img3, img4, img10, img6, img5, img7, img1, img9];

// Build an optimized full-size version of each image for the lightbox.
// getImage runs through Astro's asset pipeline (Sharp), so PhotoSwipe gets a
// cache-busted, optimized URL plus the exact width/height it needs.
const slides = await Promise.all(
  images.map(async (img, i) => {
    const full = await getImage({
      src: img,
      width: Math.min(img.width, 1600),
      format: "webp",
    });
    return {
      i,
      thumb: img,
      href: full.src,
      width: full.attributes.width ?? full.options.width ?? img.width,
      height: full.attributes.height ?? Math.round((img.height / img.width) * (full.options.width ?? img.width)),
      alt: `Hochzeitsfoto ${i + 1}`,
    };
  }),
);
---

<!-- Thumbnail grid -->
<div class="gallery wide" id="gallery">
  {
    slides.map((slide) => (
      <a
        href={slide.href}
        class="item lightbox-trigger"
        data-pswp-width={slide.width}
        data-pswp-height={slide.height}
        target="_blank"
        rel="noreferrer"
        aria-label={`Foto ${slide.i + 1} öffnen`}
      >
        <Image
          src={slide.thumb}
          alt={slide.alt}
          widths={[400, 800]}
          sizes="(min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw"
        />
      </a>
    ))
  }
</div>

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import PhotoSwipe from "photoswipe";
  import "photoswipe/style.css";

  let lightbox: PhotoSwipeLightbox | null = null;

  function initPhotoSwipe() {
    if (lightbox) {
      lightbox.destroy();
      lightbox = null;
    }

    if (!document.querySelector("#gallery .lightbox-trigger")) return;

    lightbox = new PhotoSwipeLightbox({
      gallery: "#gallery",
      children: ".lightbox-trigger",
      pswpModule: PhotoSwipe,
    });
    lightbox.init();
  }

  initPhotoSwipe();
  document.addEventListener("astro:page-load", initPhotoSwipe);
</script>

<style>
  /* ── Thumbnail grid ─────────────────────────────────────────────────────── */
  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  @media (max-width: 600px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
  @media (min-width: 601px) and (max-width: 900px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .item {
    display: block;
    overflow: hidden;
    cursor: zoom-in;
  }

  .item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 1;
    transition: opacity 0.2s;
  }

  .item:hover img {
    opacity: 0.85;
  }
</style>
