---
import Header from "../components/Header.astro";
import TranslateButton from "../components/TranslateButton.astro";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <Header />
  <main>
    <slot />
  </main>
  <TranslateButton />
</BaseLayout>
