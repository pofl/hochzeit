---
import { Font } from "astro:assets";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <title>{title}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <Font cssVariable="--font-dm-sans" preload />
    <Font cssVariable="--font-playfair-display" preload />
    <Font cssVariable="--font-tangerine" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    line-height: 1.6;
    text-align: start;
    font-size: 18px;
    font-family: var(--font-dm-sans), sans-serif;
    font-optical-sizing: auto;
    font-weight: 300;
    font-style: normal;
    font-variation-settings: "wdth" 100;

    --content-width: 35rem;
    --wide-width: 72rem;

    /* text */
    --text: #444;
    --text-muted: #666;
    --text-subtle: #555;
    --text-secondary: #5f5f5f;

    /* indian orange */
    --orange: #ff7722;
    --orange-dark: #ff5500;
    --orange-tint: color-mix(in srgb, var(--orange), white 90%);

    /* warm brown scale */
    --brown: #a15b00;
    --brown-dark: #6b4a2b;
    --brown-deeper: #3a2a1a;
    --brown-tint: rgba(161, 91, 0, 0.12);
    --brown-tint-focus: rgba(161, 91, 0, 0.45);

    /* surfaces */
    --surface-warm: #f9f6f1;
    --surface-warm-hover: #f5efe7;
    --surface-neutral: #f5f5f5;
    --surface-neutral-hover: #e8e8e8;

    /* borders */
    --border: #ddd;
    --border-soft: rgba(0, 0, 0, 0.08);
    --border-subtle: rgba(0, 0, 0, 0.06);
  }
  body {
    margin: 40px auto;
    color: var(--text);
    padding: 1rem;
  }
  main {
    max-width: var(--content-width);
    margin-left: auto;
    margin-right: auto;
  }
  .prose {
    max-width: var(--content-width);
    margin-left: auto;
    margin-right: auto;
  }
  .wide {
    width: min(var(--wide-width), calc(100vw - 2rem));
    max-width: var(--wide-width);
    margin-left: 50%;
    transform: translateX(-50%);
  }
  h1,
  h2,
  h3 {
    line-height: 1.2;
    font-family: var(--font-playfair-display), serif;
    font-optical-sizing: auto;
    font-weight: 400;
    font-style: normal;
  }
  h1 {
    font-size: 1.75rem;
  }
  h2 {
    font-size: 1.5rem;
  }
  h3 {
    font-size: 1.25rem;
  }
  strong {
    font-weight: 600;
  }
  a {
    text-decoration: none;
    color: var(--orange-dark);
    &:hover {
      text-decoration: underline;
    }
  }

  code {
    background-color: var(--orange-tint);
    color: var(--brown);
    border-radius: 4px;
    padding: 0.1em 0.35em;
    font-size: 0.875em;
  }

  p,
  blockquote {
    text-wrap: pretty;
  }

  blockquote {
    border-left: 4px solid var(--orange);
    margin-left: 0;
    margin-right: 0;
    padding: 0.5em 0.5em 0.5em 1em;
    background-color: var(--orange-tint);

    & > *:first-child {
      margin-top: 0;
    }
    & > *:last-child {
      margin-bottom: 0;
    }
  }
</style>
